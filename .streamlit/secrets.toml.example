# Copie este arquivo para .streamlit/secrets.toml e preencha os valores reais.
# NUNCA suba secrets.toml para o git.

# ID da pasta no Google Drive onde os Parquets são armazenados.
# Pegue da URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID = "cole_aqui_o_id_da_pasta"

# Credenciais da Service Account (JSON exportado do Google Cloud Console).
# No Streamlit Community Cloud: vá em Settings → Secrets e cole o bloco abaixo.
[google_service_account]
type = "service_account"
project_id = "seu-projeto-gcp"
private_key_id = "id_da_chave"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "nome-sa@seu-projeto-gcp.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
